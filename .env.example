RESEND_API_KEY=
CONTACT_TO_EMAIL=
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
NEXT_PUBLIC_SITE_URL=https://fcopts.com.br
# Cloudflare Turnstile (anti-spam do gerador de proposta).
# A SITEKEY de produção é pública e fica no código (TURNSTILE_SITE_KEY em
# GeradorProposta.tsx) — em produção a env abaixo é IGNORADA. NEXT_PUBLIC_TURNSTILE_SITE_KEY
# serve só para dev, como override da chave de teste "always pass" (1x00000000000000000000AA).
# O SECRET continua sendo env em produção (verificação server-side; teste: 1x0000000000000000000000000000000AA).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Vercel Postgres / Neon: persiste os leads do gerador de proposta e aplica o
# limite de 2 propostas por e-mail a cada 30 dias. Sem esta env, a persistência e
# o limite ficam desativados (fail-open) e o envio da proposta segue normal.
# A integração Neon na Vercel injeta DATABASE_URL automaticamente.
DATABASE_URL=
